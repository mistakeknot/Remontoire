{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mistakeknot/Remontoire/schemas/agency-v1.json",
  "title": "Interverse agency manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "name",
    "display_name",
    "description",
    "version",
    "layer",
    "class",
    "repository",
    "install",
    "runtime",
    "capabilities",
    "authority",
    "contracts"
  ],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "const": "interverse.agency/v1"},
    "kind": {"type": "string", "const": "agency"},
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "display_name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "layer": {"type": "string", "enum": ["L2"]},
    "class": {"type": "string", "enum": ["portfolio"]},
    "repository": {"type": "string", "format": "uri"},
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "check_args", "default_args", "supported_os"],
      "properties": {
        "script": {"type": "string", "minLength": 1},
        "check_args": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "default_args": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "supported_os": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binary", "doctor_args", "status_args", "service_manager", "service", "timer"],
      "properties": {
        "binary": {"type": "string", "minLength": 1},
        "doctor_args": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "status_args": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "service_manager": {"type": "string", "enum": ["systemd-user"]},
        "service": {"type": "string", "minLength": 1},
        "timer": {"type": "string", "minLength": 1}
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["may", "requires_approval", "never"],
      "properties": {
        "may": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
        },
        "requires_approval": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
        },
        "never": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
        }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*/v[0-9]+$"}
    }
  }
}
