{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mistakeknot/Remontoire/schemas/review-v1.json",
  "title": "Remontoire experiment review v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_hash", "verdict", "rationale", "evidence"],
  "properties": {
    "schema_version": {"const": "remontoire.review/v1"},
    "contract_hash": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "verdict": {"enum": ["promote", "close_success", "close_failure", "inconclusive"]},
    "rationale": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "id", "digest"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "id": {"type": "string", "minLength": 1},
          "digest": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}
        }
      }
    }
  }
}
